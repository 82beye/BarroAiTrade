# ops.env.example — 운영 머신 Hermes + advisory 파이프라인 환경변수 (시크릿은 커밋 금지)
# 사용: 값 채워 ~/.barro_ops.env 등으로 저장 → 셸 프로필/launchd EnvironmentVariables 에서 주입.
#       (BarroAiTrade .env.local 과 별개. 키만 공유.)

# ── writer LLM 백엔드(claude-cli) ──────────────────────────────────────────────
# quick-decider verdict + market_context LLM 오버레이는 `claude -p`(Claude Code CLI)를 사용.
ANTHROPIC_API_KEY=
# 시장국면 LLM 오버레이 상시 ON (writer --market-llm 대신 env 로도 가능)
# BARRO_MARKET_LLM=1

# ── Telegram (writer 표시 + Hermes 게이트웨이 공용) ───────────────────────────
# BotFather /newbot 토큰 + 개인 chat id(@userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Hermes LLM 프로바이더(택1 — hermes setup 마법사로 설정 권장) ──────────────
# Hermes 자체 추론용. writer 와 별개(writer 는 claude-cli). 운영자 대화/스킬에 사용.
#   · Nous Portal:  hermes setup --portal  (OAuth, 300+ 모델)
#   · OpenRouter:   OPENROUTER_API_KEY 설정 후 hermes model openrouter:<model>
# OPENROUTER_API_KEY=
#   · Anthropic 직결:  ANTHROPIC_API_KEY (위) 재사용 + hermes model anthropic:<model>

# ── 거래 비용(이미 코드 default, 협의요율 시만 override) ───────────────────────
# BARRO_COMMISSION_RATE=0.0035   # 편도 0.35%
# BARRO_TAX_RATE_SELL=0.0020     # 매도세 0.20%

# 참고: advisory/market-context 게이트 활성은 env 가 아니라 data/policy.json 플래그(★HITL).
#   상세: docs/operations/hermes-ops-runbook.md
