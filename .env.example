# BarroAiTrade — 환경변수 설정 예제
# 이 파일을 복사하여 .env.local로 저장하고 실제 값을 입력하세요.

# ── 트레이딩 모드 ──────────────────────────────────────────────────────────
# simulation = 모의투자 (기본값)
# live       = 실거래 (주의!)
TRADING_MODE=simulation

# ── 시장 ───────────────────────────────────────────────────────────────────
# stock  = 국내 주식 (키움증권)
# crypto = 암호화폐
TRADING_MARKET=stock

# ── Telegram 알림 봇 ────────────────────────────────────────────────────────
# BotFather에서 /newbot으로 생성
TELEGRAM_BOT_TOKEN=
# 개인 채팅 ID (https://t.me/userinfobot 으로 확인)
TELEGRAM_CHAT_ID=

# ── 키움증권 API (윈도우 환경 전용) ─────────────────────────────────────────
KIWOOM_USER_ID=
KIWOOM_PASSWORD=
KIWOOM_CERT_PASSWORD=

# ── 바이낸스 API (암호화폐) ───────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=barro1234

# ── 로깅 ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
