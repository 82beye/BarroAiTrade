# BarroAiTrade — 환경변수 설정 예제
# 이 파일을 복사하여 .env.local 로 저장하고 실제 값을 입력하세요.
# Reference: backend/config/settings.py:Settings (BAR-42 통합 스키마)

# === Trading 기본 ===
# simulation = 모의투자 (기본값) / live = 실거래 (주의!)
TRADING_MODE=simulation
# stock = 국내 주식 / crypto = 암호화폐
TRADING_MARKET=stock
SCAN_INTERVAL_SEC=3

# === Kiwoom API (모의투자 기본) ===
KIWOOM_BASE_URL=https://openapi.koreainvestment.com:9443
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
KIWOOM_ACCOUNT_NO=
KIWOOM_MOCK=true

# === DB ===
# 미설정 시 SQLite fallback (legacy 회귀 호환)
DB_PATH=data/barro_trade.db
# Postgres + pgvector (BAR-56) — DATABASE_URL 또는 POSTGRES_URL 둘 다 인식 (DATABASE_URL 우선)
# DATABASE_URL=postgresql+asyncpg://barro:barro@localhost:5432/barro
# POSTGRES_URL=postgresql+asyncpg://barro:barro@localhost:5432/barro
POSTGRES_USER=barro
POSTGRES_PASSWORD=barro
POSTGRES_DB=barro
POSTGRES_POOL_SIZE=5
PGVECTOR_ENABLED=false

# === NXT (BAR-53) ===
NXT_ENABLED=false
# NXT_BASE_URL=https://nxt.example.com
# NXT_APP_KEY=
# NXT_APP_SECRET=

# === Redis (BAR-57) ===
# REDIS_URL=redis://localhost:6379/0
REDIS_STREAMS_ENABLED=false

# === 뉴스/공시 (BAR-57) ===
# DART_API_KEY=
# RSS_FEED_URLS='["https://rss.hankyung.com/feed/economy.xml"]'  # SSRF allowlist 4 도메인만
NEWS_POLLING_INTERVAL_SEC=60
# memory(InMemory) | redis (BAR-57b 운영)
NEWS_DEDUP_BACKEND=memory
NEWS_STREAM_BACKEND=memory
NEWS_DEDUP_TTL_HOURS=24
NEWS_DEDUP_TTL_HOURS_REDIS=72
NEWS_INMEMORY_QUEUE_MAX=10000
NEWS_FETCH_TIMEOUT_SECONDS=30

# === 임베딩 (BAR-58) ===
# fake (테스트/dev) | ko_sbert (운영, revision 필수) | openai (BAR-58b)
NEWS_EMBEDDING_BACKEND=fake
NEWS_EMBEDDING_MODEL=jhgan/ko-sroberta-multitask
NEWS_EMBEDDING_DIM=768
NEWS_EMBEDDING_BATCH_SIZE=16
# CWE-494: ko_sbert 운영 진입 시 HuggingFace commit SHA 필수
# NEWS_EMBEDDING_REVISION=8b87...
# CWE-798: API 키 SecretStr
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# === 테마 분류 (BAR-59) ===
NEWS_THEME_BACKEND=three_tier
NEWS_THEME_THRESHOLD_TFIDF=0.7
NEWS_THEME_THRESHOLD_COSINE=0.5
# fixture (테마 5종 × 5건)
NEWS_THEME_LABELS_PATH=backend/tests/fixtures/theme_labels.json

# === 테마 (BAR-58/59) ===
THEME_EMBEDDING_MODEL=ko-sbert
# THEME_VECTOR_DB_URL=
THEME_CLASSIFIER_THRESHOLD=0.65

# === 보안 (BAR-67/68) ===
# JWT_SECRET=
JWT_ACCESS_TTL_SEC=3600
JWT_REFRESH_TTL_SEC=604800
MFA_ISSUER=BarroAiTrade

# === Telegram 알림 봇 ===
# BotFather 에서 /newbot 으로 생성
TELEGRAM_BOT_TOKEN=
# 개인 채팅 ID (https://t.me/userinfobot)
TELEGRAM_CHAT_ID=

# === 로깅 ===
LOG_JSON=false
LOG_LEVEL=INFO

# === 서버 ===
HOST=0.0.0.0
PORT=8000

# ─────────────────────────────────────────────────────────────────────
# 외부 인프라 (Settings 미정의 — Docker compose / 호스트 환경에서만 사용)
# 본 키들은 backend/config/settings.py:Settings 에 *없음*. 별도 인프라 도구가 직접 참조.
# ─────────────────────────────────────────────────────────────────────
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=
# BINANCE_API_KEY=        # BAR-77 코인 거래소 진입 시 도입 검토
# BINANCE_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────
# 슈퍼트렌드 자동매매 토글 (run_telegram_bot.py — os.environ 직접 참조, Settings 미정의)
# 실거래 경로: run_bot_with_env.sh 가 .env.local 을 source → 봇이 supertrend 담당.
#   SUPERTREND_AUTO_ENABLED 가 truthy 면 데몬은 supertrend 를 봇에 양보(중복주문 방지).
# 아래는 전부 주석(미설정=기본 OFF/현행 동작). .env.local 에서 필요한 것만 주석 해제.
# 권장 활성화 순서: ①LOSS_LATCH+ORDER_RETRY → ②MAX_ENTRIES+HARD_STOP+SINGLE_TRANCHE → ③RUNNER+GAP_PARTIAL
# 상세: docs/04-report/features/2026-06-09-BAR-OPS-37-env-toggles.md
# ─────────────────────────────────────────────────────────────────────
# --- 마스터 ---
# SUPERTREND_AUTO_ENABLED=1              # 봇이 supertrend 담당(데몬 양보). 미설정=데몬/수동 경로

# --- BAR-OPS-35 가드 (default OFF) ---
# SUPERTREND_AUTO_HARD_STOP=-6          # catastrophic 하드손절 %(진입가 대비). 0=off
# SUPERTREND_AUTO_MAX_ENTRIES=1         # 동일종목 당일 진입 상한(1=재진입 금지). 0=off
# SUPERTREND_AUTO_REENTRY_COOLDOWN=30   # 청산 후 재진입 cooldown(분). 0=off
# SUPERTREND_AUTO_BLOCK_REENTRY_LOSS=1  # 당일 손절종목 재진입 금지. 미설정=off
# SUPERTREND_AUTO_MAX_ATR_PCT=0.05      # 고변동(ATR/price) 종목 진입 차단. 0=off
# SUPERTREND_AUTO_TP_TRAIL_ONLY=1       # 고정익절 끄고 트레일만. 미설정=off
# SUPERTREND_AUTO_VOL_HALVE_ATR=0.05    # 고변동 종목 사이징 절반. 0=off
# SUPERTREND_AUTO_SINGLE_TRANCHE=1      # DCA 분할 미사용(sync-loss 방지). 미설정=off
# SUPERTREND_AUTO_MAX_ENTRY_GAP=3       # 추격매수 가드(직전봉比 갭 %). 0=off

# --- BAR-OPS-35 게이트(회로차단기/주문, default OFF) ---
# SUPERTREND_AUTO_LOSS_LATCH=1          # 일일손실 한도 sticky latch(회복해도 당일 잠금). off
# SUPERTREND_AUTO_ORDER_RETRY=2         # 주문 실패 재시도 횟수. 0=off
# SUPERTREND_AUTO_ORDER_RETRY_BACKOFF=0.5  # 재시도 백오프(초). 0
# SUPERTREND_AUTO_RETRY_SELL_ONLY=1     # 매도(청산)만 재시도. 미설정=on(1)

# --- BAR-OPS-36 러너(승자 보유→최고점 청산) + 익일 시가갭 부분익절 (default OFF) ---
# SUPERTREND_AUTO_RUNNER=1              # 러너 마스터(상한가/시초갭/TP후 최고점 추적). off
# SUPERTREND_AUTO_RUNNER_LIMIT_UP=29    # 상한가 판정 %(전일종가比, 트리거+홀딩)
# SUPERTREND_AUTO_RUNNER_GAP_UP=5       # 보유종목 시초갭 러너 트리거 %. 0=off
# SUPERTREND_AUTO_RUNNER_GIVEBACK=3     # 최고점 되돌림 청산 %(추세이탈)
# SUPERTREND_AUTO_RUNNER_GIVEBACK_ATR=0 # >0 이면 peak−mult×ATR (giveback% 대신)
# SUPERTREND_AUTO_RUNNER_LOCK=2         # 러너 수익잠금 floor %(승자→손실 방지)
# SUPERTREND_AUTO_GAP_PARTIAL=0.5       # 익일 시가갭 부분익절 비율(0.5=절반). 0=off
# SUPERTREND_AUTO_GAP_PARTIAL_MIN=3     # 부분익절 최소 갭 %
# SUPERTREND_AUTO_GAP_PARTIAL_WINDOW=6  # 개장 후 N봉(×5분) 이내만

# --- 기존 운영 노브 (이름 참조 — 기본값은 run_telegram_bot.py) ---
# SUPERTREND_AUTO_DAILY_LOSS_LIMIT=-3.0   # 일일손실 한도 %
# SUPERTREND_AUTO_UNIVERSE_TOP / _INTERVAL_SEC / _MAX_POS / _ENTRY_START(09:30)
# SUPERTREND_AUTO_MIN_ADX / _MIN_FLIP / _MAX_ORDER_QTY / _MAX_ORDER_VALUE
# SUPERTREND_AUTO_TRAIL_ATR(0) / _ENTRY_LOOKBACK / _RSI(+_RSI_TF/_PERIOD/_SIGNAL/_MODE/_LOOKBACK/_EXIT)

# ─────────────────────────────────────────────────────────────────────
# 에이전트 자문(advisory) — Hermes/quick-decider verdict → data/advisory.json (생산자)
#   writer(scripts/agent_advisory_writer.py)만 사용. 데몬 게이트 활성은 env 가 아니라
#   data/policy.json 의 agent_advisory_enabled(★HITL). git pull → make advisory-setup.
#   상세: docs/operations/agent-advisory-runbook.md
# ─────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=                      # --backend claude-cli(quick-decider) 호출에 필요
# TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID 는 위 'Telegram 알림 봇' 섹션 재사용(--telegram 표시)
# 참고(policy.json 키 — env 아님): agent_advisory_enabled(false=기본,게이트OFF)/
#   agent_advisory_ttl_sec(180)/ agent_advisory_block_wait(false)/ agent_advisory_min_confidence(0.0)
